# Salesforce username/password+token (simple dev flow)
SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=your_salesforce_username
SF_PASSWORD=your_salesforce_password
SF_TOKEN=your_salesforce_security_token

# Alternatively you can set an existing access token and instance url
# SF_ACCESS_TOKEN=00D...!AQo...
# SF_INSTANCE_URL=https://your-instance.my.salesforce.com

# Map SObject API names if your org uses different names
SF_SOBJECT_EVENT=Event__c
SF_SOBJECT_VOLUNTEER=Volunteer__c
SF_SOBJECT_REGISTRATION=Registration__c
SF_SOBJECT_VOLUNTEERHOURS=VolunteerHours__c
SF_SOBJECT_HISTORY=History__c
